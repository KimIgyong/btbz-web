# btbz-cms server environment / 서버 환경변수 (실값은 서버에만 보관 — git 커밋 금지)
PORT=3100
DB_PATH=/var/lib/btbz-cms/btbz-cms.sqlite

# JWT
JWT_SECRET=change-me-long-random-string
JWT_EXPIRES_IN=12h

# Gmail SMTP (앱 비밀번호 사용 / use an app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-app-password
MAIL_TO=fremdung@gmail.com

# 초기 어드민 시드 (최초 기동 시 1회 생성, 최초 로그인 시 비밀번호 변경 강제)
SEED_ADMIN_EMAIL=admin@btbz.ai
SEED_ADMIN_PASSWORD=set-initial-password-here
